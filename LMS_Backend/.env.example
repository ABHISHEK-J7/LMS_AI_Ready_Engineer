# Copy to .env and fill in real values. NEVER commit a real .env — it is git-ignored.
# This .example file is committed, so it must contain PLACEHOLDERS ONLY.

# ── Server ──────────────────────────────────────────────
PORT=5050
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the SPA dev server, etc.)
CORS_ORIGIN=http://localhost:5173

# Public base URL of the SPA — certificate verification links / QR codes point here.
APP_BASE_URL=http://localhost:5173

# ── Observability & data retention ──────────────────────
# Log verbosity: debug | info | warn | error. Defaults to debug in dev, info in prod.
# Logs emit one structured JSON line per event in production.
LOG_LEVEL=
# Optional Sentry DSN for error monitoring. When set AND @sentry/node is installed
# (`npm i @sentry/node`), 5xx errors + uncaught exceptions are reported. No-op otherwise.
SENTRY_DSN=
# GDPR retention: purge webcam proctor snapshots this many days after the attempt.
# Set 0 to keep them forever (disables the retention sweep). Default: 90.
PROCTOR_RETENTION_DAYS=90

# ── Scale-out (all optional) ────────────────────────────────────────────────
# Redis — required to run MORE THAN ONE backend instance. Enables a shared
# rate-limit store, cross-instance auth-cache invalidation, and single-leader
# election for the exam sweeper. Leave empty for a single instance.
REDIS_URL=

# S3 (or S3-compatible: Cloudflare R2 / MinIO) for uploads + a CDN. When set,
# new uploads stream to object storage and are served via short-lived presigned
# redirects (media bytes bypass Node + Mongo). GridFS stays the fallback for any
# pre-existing files. Leave S3_BUCKET empty to keep everything in GridFS.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# ── Database ────────────────────────────────────────────
# Local:  mongodb://localhost:27017/lms_ai_ready
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/lms_ai_ready

# ── Auth ────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In production the server REFUSES to boot if these are unset.
JWT_ACCESS_SECRET=change-me-generate-a-long-random-secret
JWT_REFRESH_SECRET=change-me-generate-a-different-long-random-secret

# ── AI evaluation engine (LMS_AI_Engine) ────────────────
# Claude API key — enables AI grading of prompt-writing & coding submissions.
# Without it, non-MCQ submissions stay in "submitted / pending review".
ANTHROPIC_API_KEY=
# Optional: lifts GitHub rate limits when reviewing project repositories.
GITHUB_TOKEN=

# ── Zoom (optional) — auto-create class meeting links ───
# Server-to-Server OAuth app credentials (zoom.us → Develop → Build App → S2S OAuth).
# Can also be set by an admin in the Settings UI. Env vars take precedence.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── LiveKit (optional) — in-app live classes (no external meeting provider) ──
# Self-host LiveKit (docker run livekit/livekit-server --dev) or use LiveKit Cloud.
# The backend mints join tokens; the SPA connects to LIVEKIT_URL (wss://...).
# When unset, classes can still use external links; "In-app live class" is disabled.
#   LIVEKIT_URL=wss://your-project.livekit.cloud   (or ws://localhost:7880 in dev)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Email (password-OTP onboarding) ─────────────────────
# SMTP for sending the branded one-time codes. REQUIRED in production — the OTP
# is never shown in the UI. If SMTP_HOST is blank, dev logs the code to the
# server console only (no email, never surfaced to the browser).
#
# Examples:
#   Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#             SMTP_USER=you@gmail.com   SMTP_PASS=<16-char App Password>
#             (Google Account → Security → 2-Step Verification → App passwords)
#   SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=<API key>
#   Mailgun/Resend/SES: use the SMTP host + credentials from their dashboard.
# Port 465 → SMTP_SECURE=true; port 587 (STARTTLS) → SMTP_SECURE=false.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Use a from-address on a domain you're allowed to send from (your SMTP user's domain).
MAIL_FROM=AI Ready Engineer <no-reply@yourdomain.com>

# ── Seed admin (used by `npm run seed`) ─────────────────
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_EMAIL=admin@aiready.local
SEED_ADMIN_PASSWORD=ChangeMe123!
