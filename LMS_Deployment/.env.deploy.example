# Copy to `.env` in this directory before `docker compose up`. PLACEHOLDERS ONLY here.
# Generate secrets: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# Public origin the browser will use (drives CORS + certificate verify links).
PUBLIC_ORIGIN=http://localhost:8080
PUBLIC_PORT=8080

# Auth secrets — REQUIRED (compose refuses to start without them).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Optional: use Atlas instead of the bundled mongo (then remove the mongo service).
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# Optional: enable AI grading.
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
